#!/usr/bin/env python3
"""
Web API service for Whisper transcription
Provides FastAPI endpoints for processing audio files
"""

import os
import tempfile
import shutil
from typing import Optional
from fastapi import FastAPI, File, UploadFile, HTTPException, Depends
from fastapi.responses import JSONResponse
import uvicorn
from pydantic import BaseModel
from transcribe import WhisperTranscriber

app = FastAPI(title="Whisper Transcription Service", version="1.0.0")

class TranscriptionRequest(BaseModel):
    language: Optional[str] = None

# Global transcriber instance
transcriber = None

def get_transcriber():
    global transcriber
    if transcriber is None:
        api_key = os.getenv('OPENAI_API_KEY')
        if not api_key:
            raise HTTPException(status_code=500, detail="OpenAI API key not configured")
        transcriber = WhisperTranscriber(api_key=api_key)
    return transcriber

@app.get("/health")
async def health_check():
    """Health check endpoint"""
    return {"status": "healthy", "service": "whisper-transcription"}

@app.post("/transcribe")
async def transcribe_audio(
    file: UploadFile = File(...),
    language: Optional[str] = None,
    transcriber: WhisperTranscriber = Depends(get_transcriber)
):
    """
    Upload an audio file for transcription
    Supports: .ogg, .mp3, .wav, .m4a
    """
    
    if not file.filename:
        raise HTTPException(status_code=400, detail="No file uploaded")
    
    # Validate file type
    allowed_extensions = {'.ogg', '.mp3', '.wav', '.m4a', '.flac'}
    file_extension = os.path.splitext(file.filename)[1].lower()
    
    if file_extension not in allowed_extensions:
        raise HTTPException(
            status_code=400, 
            detail=f"Invalid file type. Allowed: {', '.join(allowed_extensions)}"
        )
    
    # Save uploaded file to temporary location
    with tempfile.NamedTemporaryFile(
        suffix=file_extension, 
        delete=False, 
        dir=tempfile.gettempdir()
    ) as tmp_file:
        content = await file.read()
        tmp_file.write(content)
        tmp_path = tmp_file.name
    
    try:
        # Transcribe the audio
        result = transcriber.transcribe_audio(tmp_path, language=language)
        
        if "error" in result:
            raise HTTPException(status_code=500, detail=result["error"])
        
        # Remove file extension from key
        result["original_filename"] = file.filename
        
        return JSONResponse(content=result)
        
    finally:
        # Clean up temporary file
        if os.path.exists(tmp_path):
            os.unlink(tmp_path)

@app.get("/supported-formats")
async def get_supported_formats():
    """Get list of supported audio formats"""
    return {
        "formats": [".ogg", ".mp3", ".wav", ".m4a", ".flac"],
        "description": "Audio formats supported for transcription"
    }

if __name__ == "__main__":
    port = int(os.getenv("PORT", 8000))
    host = os.getenv("HOST", "0.0.0.0")
    uvicorn.run(app, host=host, port=port)